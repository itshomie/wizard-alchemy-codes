---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section class="section" aria-labelledby="faq">
  <div class="wrap prose">
    <h2 id="faq">FAQ</h2>
    {
      items.map((item) => (
        <article class="faq-item">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </article>
      ))
    }
  </div>
</section>
