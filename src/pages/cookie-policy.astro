---
import BaseLayout from "../layouts/BaseLayout.astro";
import { lastCheckedLabel, pages } from "../data/site";

const page = pages.find((item) => item.pathname === "/cookie-policy/")!;
---

<BaseLayout title={page.title} description={page.description} pathname="/cookie-policy/">
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Site policy</p>
      <h1>Cookie Policy</h1>
      <p class="lead">This guide site is static and does not need tracking cookies to function.</p>
      <div class="meta-row">
        <span class="badge">Last updated: {lastCheckedLabel}</span>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="wrap prose">
      <h2>Current Cookie Use</h2>
      <p>
        Wizard Alchemy Codes & Guides does not set first-party tracking cookies.
        Browser or hosting infrastructure may still use technical storage for
        normal web delivery and security.
      </p>
      <h2>Advertising and Analytics</h2>
      <p>
        This site does not currently run display ads, affiliate tracking, or
        third-party analytics scripts.
      </p>
      <h2>Managing Cookies</h2>
      <p>
        You can manage cookies through your browser settings. Blocking cookies
        may affect third-party pages linked from this site.
      </p>
    </div>
  </section>
</BaseLayout>
