---
import BaseLayout from "../layouts/BaseLayout.astro";
import { lastCheckedLabel, pages } from "../data/site";

const page = pages.find((item) => item.pathname === "/cookie-policy/")!;
---

<BaseLayout title={page.title} description={page.description} pathname="/cookie-policy/">
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Site policy</p>
      <h1>Cookie Policy</h1>
      <p class="lead">The MVP site is static and does not need tracking cookies to function.</p>
      <div class="meta-row">
        <span class="badge">Last updated: {lastCheckedLabel}</span>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="wrap prose">
      <h2>Current Cookie Use</h2>
      <p>
        The MVP version does not set first-party tracking cookies. Browser or
        hosting infrastructure may still use technical storage for normal web
        delivery.
      </p>
      <h2>Future Advertising or Analytics</h2>
      <p>
        If analytics, affiliate tracking, or ads are added later, this policy
        should be updated before launch and a cookie consent flow should be
        added where required.
      </p>
      <h2>Managing Cookies</h2>
      <p>
        You can manage cookies through your browser settings. Blocking cookies
        may affect third-party pages linked from this site.
      </p>
    </div>
  </section>
</BaseLayout>
